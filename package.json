{
  "name": "prisma4postgres",
  "productName": "Prisma4Postgres",
  "description": "PostgreSQL database explorer and query runner",
  "version": "11.1.0",
  "author": {
    "name": "britors",
    "email": "rodrigo@w3ti.com.br"
  },
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/britors/Prisma4Postgres.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node esbuild.js && electron out/main/index.js",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production && electron-builder --publish never",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/__tests__/PgConnection.test.ts src/__tests__/PrismaParser.test.ts src/__tests__/ConnectionManager.test.ts",
    "flatpak:gen-sources": "flatpak-node-generator npm package-lock.json -o flatpak/generated-sources.json",
    "flatpak:build": "flatpak-builder --force-clean build-dir flatpak/br.com.w3ti.Prisma4Postgres.yml",
    "flatpak:run": "flatpak-builder --force-clean --run build-dir flatpak/br.com.w3ti.Prisma4Postgres.yml run.sh"
  },
  "build": {
    "appId": "com.britors.prisma4postgres",
    "productName": "Prisma4Postgres",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "npmRebuild": false,
    "linux": {
      "target": [
        "deb",
        "rpm"
      ],
      "icon": "logo.svg"
    },
    "win": {
      "target": "nsis",
      "icon": "logo.ico"
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.0",
    "@types/ssh2": "^1.15.5",
    "@vscode/codicons": "^0.0.45",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "playwright-core": "^1.60.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "pg": "^8.11.0",
    "ssh2": "^1.17.0"
  }
}
